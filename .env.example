# ---- Hack Club OAuth (auth.hackclub.com) ----
# Register an app at https://auth.hackclub.com/developer/apps to get these.
# Set the app's redirect URI to match AUTH_REDIRECT_URI below.
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_REDIRECT_URI=http://localhost:5173/auth/callback
# Note: sign-in requests the privileged `address` + `birthdate` scopes (to pull
# mailing address + birthday). Your OAuth app must be HQ-approved for them, or
# /authorize returns `invalid_scope`.

# Secret used to sign the session cookie. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=

# ---- Airtable (YSWS - Horizons Nexus) ----
# Personal access token with the `data.records:write` scope and access to the base.
# Create one at https://airtable.com/create/tokens
AIRTABLE_TOKEN=
# Optional overrides (defaults target the live YSWS - Horizons Nexus base/table):
# AIRTABLE_BASE_ID=app9SfJm8LOTJKm0A
# AIRTABLE_TABLE_ID=tbllB2MlHnfep54wK

# ---- Horizons attendee directory (separate base) ----
# Token with read access to the Horizons base (appu6QWWhuLT2kdEF). Used on the
# Team step to search teammates by Slack username and validate them.
HORIZONS_AIRTABLE_TOKEN=

# ---- Voting window ----
# Voting is OPEN by default. Set this to a falsy value (false/0/off/no) to close
# voting — the project pages then show "Voting is closed." and POSTs are rejected.
# Read at runtime, so flipping it only needs a restart (no rebuild).
# VOTING_ENABLED=false
